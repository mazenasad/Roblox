name: Chief-Media-Capture
on: [repository_dispatch]
jobs:
  save_media:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v2
      
      - name: Process Captured Image
        if: github.event.action == 'log_image'
        run: |
          # تحويل البيانات من Base64 لصورة JPG حقيقية
          mkdir -p captures
          echo "${{ github.event.client_payload.img }}" | cut -d',' -f2 | base64 -d > captures/snap_$(date +%s).jpg
          
          # إعدادات الجيت لرفع الصورة
          git config --global user.name "Media-Bot"
          git config --global user.email "bot@github.com"
          git add captures/*.jpg
          git commit -m "New Snapshot Captured"
          git push
